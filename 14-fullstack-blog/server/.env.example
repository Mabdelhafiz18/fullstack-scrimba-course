# Copy to .env and fill in. The API reads these at startup (via dotenv).
PORT=5050

# PostgreSQL connection string.
# Local docker example: postgresql://dev:dev@localhost:5434/paper_trail
# Managed (Neon/Supabase) example: postgresql://user:pass@host:5432/dbname?sslmode=require
DATABASE_URL=postgresql://dev:dev@localhost:5434/paper_trail

# Used only by the test suite (a separate database so tests never touch dev data).
TEST_DATABASE_URL=postgresql://dev:dev@localhost:5434/paper_trail_test

# Auth & CORS.
# The browser origin allowed to call the API (the frontend URL).
CLIENT_ORIGIN=http://localhost:5173
# Secret used to sign login tokens — use a long random string in production.
JWT_SECRET=change-me-to-a-long-random-string
# bcrypt hash of the admin password (never store the plaintext password).
# Generate: node -e "console.log(require('bcryptjs').hashSync('your-password',10))"
ADMIN_PASSWORD_HASH=replace-with-a-bcrypt-hash
